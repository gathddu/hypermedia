---
import Base from '../layouts/Base.astro';

const projects = [
  {
    name: 'hypermedia',
    tagline: 'personal site :: you are here',
    description: 'a node on the web.',
    tech: ['astro', 'typescript', 'css'],
    links: [{ label: 'github', href: 'https://github.com/gathddu/hypermedia' }],
    status: 'wip',
  },
  {
    name: 'the computer science bible',
    tagline: 'knowledge graph :: open-source',
    description: 'an open, collaborative guide to the theory, practice and metacognition of computing. structured as a digital garden for obsidian.',
    tech: ['markdown', 'obsidian'],
    links: [{ label: 'github', href: 'https://github.com/gathddu/the-computer-science-bible' }],
    status: 'wip',
  },
  {
    name: 'threadbear',
    tagline: 'e-mail client :: because thunderbird sucks',
    description: 'building an e-mail client from scratch in rust because existing ones made me mad enough to try.',
    tech: ['rust'],
    links: [{ label: 'github', href: 'https://github.com/gathddu/threadbare' }],
    status: 'wip',
  },
  {
    name: 'sentinel',
    tagline: 'intrusion detection :: network security',
    description: 'production-ready IDS that detects network attacks and anomalies in real-time. multi-layer detection with ML anomaly detection, signature matching and correlation engine.',
    tech: ['rust', 'nix', 'clickhouse', 'grafana', 'docker'],
    links: [{ label: 'github', href: 'https://github.com/gathddu/Sentinel' }],
    status: 'wip',
  },
  {
    name: 'moonlight',
    tagline: 'distributed storage :: peer-to-peer',
    description: 'high-availability p2p file syncronization system. creates a personal cloud across your own devices with leader-follower consensus.',
    tech: ['java', 'docker', 'kubernetes', 'react'],
    links: [{ label: 'github', href: 'https://github.com/gathddu/moonlight' }],
    status: 'wip',
  },
  {
    name: 'linux',
    tagline: 'workshop :: linux from scratch',
    description: 'university workshop where students build a linux distribution from source. curriculum design, written materials, semester-long classes.',
    tech: ['linux', 'shell'],
    links: [{ label: 'github', href: 'https://github.com/monitoria-ti-ceub/linux' }],
    status: 'wip',
  },
  {
    name: 'scscon',
    tagline: 'urban safety :: hackathon project',
    description: 'collaborative security platform with geolocation alerts, real-time heatmaps and social assistance integration. built for a public services innovation hackathon.',
    tech: ['typescript', 'react', 'trpc', 'tailwindcss', 'drizzle', 'leaflet'],
    links: [{ label: 'github', href: 'https://github.com/gathddu/scscon' }],
    status: 'wip',
  },
  {
    name: 'onboard',
    tagline: 'internship project :: gestão de beneficiários',
    description: 'full-stack system for managing social security beneficiaries at dataprev. rest api, react front-end, microservices and docker.',
    tech: ['java', 'spring boot', 'spring cloud', 'react', 'postgresql', 'docker'],
    links: [
      { label: 'github', href: 'https://github.com/gathddu/OnBoard' },
    ],
    status: 'complete',
  },
  {
    name: 'tickr',
    tagline: 'task manager :: work in progress',
    description: 'a personal task management application. details to come.',
    tech: ['react', 'typescript', 'trpc', 'postgresql'],
    links: [],
    status: 'wip',
  },
];
---

<Base title="code" description="projects and portfolio">
  <section class="code-page">

    <div class="page-header">
      <span class="breadcrumb">~/ code</span>
      <h1>code</h1>
      <p class="subtitle">things i've built or am building</p>
    </div>

    <div class="projects">
      {projects.map((p, i) => (
        <article class="project-card" data-index={i}>
          <div class="project-top">
            <div class="project-title-row">
              <h2 class="project-name">{p.name}</h2>
              <span class:list={['status-badge', p.status]}>
                {p.status === 'complete' ? '✓ complete' : '⟳ wip'}
              </span>
            </div>
            <p class="project-tagline">{p.tagline}</p>
          </div>

          <p class="project-desc">{p.description}</p>

          <div class="project-tech">
            {p.tech.map((t) => <span class="tag">{t}</span>)}
          </div>

          {p.links.length > 0 && (
            <div class="project-links">
              {p.links.map((l) => (
                <a href={l.href} target="_blank" rel="noopener" class="proj-link">
                  ↗ {l.label}
                </a>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>

    <div class="pagination">
      <button class="page-btn" id="prev-btn" disabled>← prev</button>
      <span class="page-info" id="page-info">1 / 3</span>
      <button class="page-btn" id="next-btn">next →</button>
    </div>


  </section>
</Base>

<script>
  const PER_PAGE = 8;
  const cards = document.querySelectorAll('.project-card');
  const total = cards.length;
  const totalPages = Math.ceil(total / PER_PAGE);
  let current = 0;

  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const pageInfo = document.getElementById('page-info');

  function render() {
    const start = current * PER_PAGE;
    const end = start + PER_PAGE;
    cards.forEach((card, i) => {
      card.style.display = (i >= start && i < end) ? '' : 'none';
    });
    pageInfo.textContent = `${current + 1} / ${totalPages}`;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === totalPages - 1;
  }

  prevBtn.addEventListener('click', () => { current--; render(); window.scrollTo(0, 0); });
  nextBtn.addEventListener('click', () => { current++; render(); window.scrollTo(0, 0); });

  render();
</script>

<style>
  .code-page {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .page-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
  }

  .breadcrumb {
    font-size: 0.75rem;
    color: var(--text-dim);
    display: block;
    margin-bottom: 0.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin: 0;
  }

  .projects {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-card {
    border: 1px solid var(--border);
    background: var(--bg-panel);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.15s;
  }

  .project-card:hover {
    border-color: var(--border-bright);
  }

  .project-top {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .project-name {
    font-size: 1.3rem;
    color: var(--accent);
    margin: 0;
  }

  .status-badge {
    font-size: 0.7rem;
    padding: 0.15em 0.5em;
    border-radius: 2px;
    font-family: var(--mono);
  }

  .status-badge.complete {
    background: var(--accent-dark);
    color: var(--accent);
    border: 1px solid var(--accent-dim);
  }

  .status-badge.wip {
    background: #1a1500;
    color: var(--yellow);
    border: 1px solid #665500;
  }

  .project-tagline {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin: 0;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--text);
    margin: 0;
    max-width: 60ch;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .proj-link {
    font-size: 0.85rem;
    color: var(--accent);
  }

  .more-note {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .dim { color: var(--text-dim); }

  .pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  margin-top: 2rem;
  padding: 1rem 0;
}

.page-btn {
  background: none;
  border: 1px solid var(--border);
  color: var(--accent);
  padding: 0.4rem 1rem;
  font-family: inherit;
  font-size: 0.8rem;
  cursor: pointer;
  transition: border-color 0.2s;
}

.page-btn:hover:not(:disabled) {
  border-color: var(--accent);
}

.page-btn:disabled {
  color: var(--text-dim);
  cursor: not-allowed;
  opacity: 0.4;
}

.page-info {
  font-size: 0.8rem;
  color: var(--text-dim);
}

</style>

