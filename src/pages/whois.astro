---
import Base from '../layouts/Base.astro';
---

<Base title="whois" description="about gathddu">
    <article class="whois">
        <div class="page-header">
            <span class="breadcrumb">~/ whois</span>
            <h1>whois gathddu</h1>
            <p class="subtitle">an incomplete record</p>
        </div>


        <section class="block">
            <h2>// identity</h2>
            <div class="kv-table">
                <div class="kv-row">
                    <span class="kv-key">name</span>
                    <span class="kv-val">jess</span>
                </div>
                <div class="kv-row">
                    <span class="kv-key">location</span>
                    <span class="kv-val">brazil</span>
                </div>
                <div class="kv-row">
                    <span class="kv-key">day job</span>
                    <span class="kv-val">software developer @ <a href="https://www.dataprev.gov.br" target="_blank">dataprev</a></span>
                </div>
                <div class="kv-row">
                    <span class="kv-key">stack</span>
                    <span class="kv-val">java · spring boot · react · postgres · docker</span>
                </div>
                <div class="kv-row">
                    <span class="kv-key">os</span>
                    <span class="kv-val">nixos (btw)</span>
                </div>
                <div class="kv-row">
                    <span class="kv-key">alignment</span>
                    <span class="kv-val">chaotic good</span>
                </div>
            </div>
        </section>

            <section class="block">
      <h2>// about</h2>
      <p>
        i write code for a living and for fun. currently building government systems at dataprev
        — the tech backbone of brazil's social security. the stack is java and spring boot,
        which means i've developed strong opinions about enterprise software.
      </p>
      <p>
        outside of work — art, video-games and salt & vinegar crisps. i like board games with too many rules
        and techno with too few. i run nixos because i like control and i like suffering in equal measure.
      </p>
      <p>
        this site is where i put things i'm working on, thinking about, or just found interesting.
        no algorithm, no engagement metrics, no dark patterns. just a place on the internet that's mine.
      </p>
    </section>


        <section class="block">
      <h2>// skills</h2>
      <div class="skill-grid">
        <div class="skill-group">
          <span class="skill-cat">back-end</span>
          <div class="tags">
            <span class="tag">java</span>
            <span class="tag">spring boot</span>
            <span class="tag">spring cloud</span>
            <span class="tag">jpa/hibernate</span>
            <span class="tag">rest apis</span>
            <span class="tag">microservices</span>
          </div>
        </div>
        <div class="skill-group">
          <span class="skill-cat">front-end</span>
          <div class="tags">
            <span class="tag">react</span>
            <span class="tag">astro</span>
            <span class="tag">typescript</span>
            <span class="tag">css</span>
            <span class="tag">vite</span>
          </div>
        </div>
        <div class="skill-group">
          <span class="skill-cat">infrastructure</span>
          <div class="tags">
            <span class="tag">docker</span>
            <span class="tag">postgresql</span>
            <span class="tag">nginx</span>
            <span class="tag">nixos</span>
            <span class="tag">git</span>
          </div>
        </div>
      </div>
    </section>

    <section class="block">
      <h2>// find me</h2>
      <div class="links">
        <a href="https://github.com/gathddu" target="_blank" rel="noopener" class="ext-link">
          <span class="ext-icon">⌥</span> github.com/gathddu
        </a>
        <a href="https://linkedin.com/in/jesssaitoforster" target="_blank" rel="noopener" class="ext-link">
          <span class="ext-icon">⌥</span> linkedin.com/in/jesssaitoforster
        </a>
        <a href="mailto:jessforsterdev@gmail.com" target="_blank" rel="noopener" class="ext-link">
          <span class="ext-icon">⌥</span> jessforsterdev@gmail.com
        </a>
      </div>
    </section>

  </article>
</Base>

<style>
  .whois {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .page-header {
    border-bottom: 1px solid var(--border );
    padding-bottom: 1.5rem;
  }

  .breadcrumb {
    font-size: 0.75rem;
    color: var(--text-dim);
    display: block;
    margin-bottom: 0.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin: 0;
  }

  .block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .kv-table {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border: 1px solid var(--border);
    background: var(--bg-panel);
    padding: 1rem 1.2rem;
  }

  .kv-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1rem;
    font-size: 0.85rem;
  }

  .kv-key {
    color: var(--accent);
    font-weight: 600;
  }

  .kv-val {
    color: var(--text);
  }

  .skill-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .skill-cat {
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ext-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .ext-icon {
    color: var(--accent);
    font-size: 0.8rem;
  }
</style>