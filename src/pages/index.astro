---
import Base from '../layouts/Base.astro';
---

<Base title="home">
	<section>
		<div class="prompt-line">
			<span class="prompt">~</span>
			<span class="command">whoami</span>
		</div>
		<h1 class="cursor">jess</h1>
		<p class="tagline">software developer @ <a href="https://www.dataprev.gov.br" target="_blank">dataprev</a></p>
	</section>

	<hr/>

	<section class="bio">
		<p>
			i write code for a living and for fun. currently building internal systems
			for the brazilian social security infrastructure. interested in clean architecture,
			creative coding and making things that feel good to use.
		</p>
		<p>
			this site is where i keep my work, experiments and whatever else i feel like putting here.
		</p>
	</section>

	<hr/>

	<section class="cards">
		<a href="/whois" class="card">
			<span class="card-icon">◈</span>
			<span class="card-label">whois</span>
			<span class="card-desc">who i am</span>
		</a>
		<a href="/code" class="card">
			<span class="card-icon">&lt;/&gt;</span>
			<span class="card-label">code</span>
			<span class="card-desc">things i've built</span>
		</a>
		<a href="/lab" class="card">
			<span class="card-icon">⚗</span>
			<span class="card-label">lab</span>
			<span class="card-desc">experiments</span>
		</a>
		<a href="/blog" class="card">
			<span class="card-icon">✦</span>
			<span class="card-label">blog</span>
			<span class="card-desc">writing</span>
		</a>
	</section>
</Base>

<style>
	h1 {
		font-size: 2rem;
		margin-bottom: 0.25rem;
	}

	.tagline {
		color: var(--text-dim);
		font-size: 0.9rem;
	}

	.bio p {
		margin-bottom: 1rem;
	}

	.prompt-line {
		font-size: 0.85rem;
		color: var(--text-dim);
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}

	.prompt {
		color: var((--accent));
	}

	.command {
		color: var(--text-bright);
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		border: 1px solid var(--border);
	}

	.card {
		display: grid;
		grid-template-rows: auto auto;
		grid-template-columns: auto 1fr;
		column-gap: 0.75rem;
		padding: 1rem;
		text-decoration: none;
		border: none;
		transition: background 0.15s;
	}

	.card:hover {
		background: var(--surface);
	}

	.card-icon {
		grid-row: 1 / 3;
		align-self: center;
		color: var(--accent);
		font-size: 1rem;
	}

	.card-label {
		color: var(--text-bright);
		font-size: 0.9rem;
	}

	.card-desc {
		color: var(--text-dim);
		font-size: 0.78rem;
	}
</style>

