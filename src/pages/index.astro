---
import Base from '../layouts/Base.astro';
---

<Base title="home">
    <section class="home">
		<div class="prompt-line">
			<span class="prompt">~/</span>
			<span class="command">whoami</span>
		</div>
		<div class="output">
			<h1 class="cursor">jess</h1>
			<p class="tagline">software developer @ <a href="https://www.dataprev.gov.br" target="_blank">dataprev</a></p>
		</div>
		<div class="divider"></div>

	    <div class="quick-links">
        	<a href="/whois" class="ql-card">
            	<span class="ql-icon">₍^ >⩊< ^₎Ⳋ</span>
            	<span class="ql-label">whois</span>
            	<span class="ql-desc">about me</span>
        	</a>
        	<a href="/code" class="ql-card">
            	<span class="ql-icon">🖥️૮・ﻌ・ა</span>
            	<span class="ql-label">code</span>
            	<span class="ql-desc">projects &amp; portfolio</span>
        	</a>
        	<a href="/lab" class="ql-card">
            	<span class="ql-icon">⋆˚꩜｡⋆. ⌬ ˚</span>
            	<span class="ql-label">lab</span>
            	<span class="ql-desc">experiments &amp; art</span>
        	</a>
			<a href="/blog" class="ql-card">
            	<span class="ql-icon">໒(⊙ᴗ⊙)७✎▤</span>
            	<span class="ql-label">blog</span>
            	<span class="ql-desc">writing</span>
        	</a>
    	</div>

    	<div class="divider"></div>

    	<div class="status-line">
        	<span class="status-item"><span class="dot green"></span>available for collaboration</span>
        	<span class="status-item"><span class="dot yellow"></span>building things at dataprev</span>
        	<span class="status-item"><span class="dot blue"></span>nixos enjoyer</span>
    	</div>
	</section>
</Base>

<style>
	.home {
		display: flex;
		flex-direction: column;
		gap: 2rem;
  	}

  	.prompt-line {
    	font-size: 0.85rem;
    	color: var(--text-dim);
    	display: flex;
    	gap: 0.5rem;
  	}

  	.prompt {
		color: var(--accent); 
	}

  	.command {
		color: var(--text-bright);
	}

    .output h1 {
    	font-size: 2.5rem;
    	letter-spacing: -0.02em;
    	margin-bottom: 0.25rem;
  	}

  	.tagline {
    	color: var(--text-dim);
    	font-size: 0.9rem;
    	margin: 0;
  	}

  	.divider {
    	border-top: 1px solid var(--border);
  	}

  	.quick-links {
    	display: grid;
    	grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    	gap: 1rem;
  	}

  	.ql-card {
    	display: flex;
    	flex-direction: column;
    	gap: 0.25rem;
    	padding: 1rem 1.2rem;
    	border: 1px solid var(--border);
    	border-radius: 2px;
    	background: var(--bg-panel);
    	text-decoration: none;
    	transition: all 0.15s;
  	}

  	.ql-card:hover {
    	border-color: var(--accent);
    	background: var(--accent-dark);
    	text-decoration: none;
  	}

  	.ql-icon {
    	font-size: 1.2rem;
    	color: var(--accent);
    	margin-bottom: 0.25rem;
  	}

  	.ql-label {
    	font-weight: 600;
    	color: var(--text-bright);
    	font-size: 1rem;
  	}

  	.ql-desc {
    	font-size: 0.75rem;
    	color: var(--text-dim);
  	}

  	.status-line {
    	display: flex;
    	flex-wrap: wrap;
    	gap: 1.5rem;
    	font-size: 0.8rem;
    	color: var(--text-dim);
  	}

  	.status-item {
    	display: flex;
    	align-items: center;
    	gap: 0.4rem;
  	}

  	.dot {
    	width: 6px;
    	height: 6px;
    	border-radius: 50%;
    	flex-shrink: 0;
  	}

  	.dot.green { background: var(--accent); }
  	.dot.yellow { background: var(--yellow); }
  	.dot.blue { background: var(--blue); }
</style>


