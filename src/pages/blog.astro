---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = (await getCollection("blog"))
    .filter((post: CollectionEntry<'blog'>) => !post.data.draft)
    .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="blog">
    <div class="prompt-line">
        <span class="prompt">~/blog</span>
        <span class="command">ls -la</span>
    </div>

    <h2>blog</h2>

    <p class="intro">notes on code, systems and whatever is on my mind.</p>

    <div class="psots">
        {posts.map((post: CollectionEntry<'blog'>) => (
            <article class="post">
                <div class="post-header">
                    <span class="post-date">
                        {post.data.date.toISOString().slice(0, 10)}
                    </span>
                    <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
                </div>
                {post.data.description && (
                    <p class="post-desc">{post.data.description}</p>
                )}
            </article>
        ))}
    </div>
</Base>

<style>
    h2 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: var(--accent);
    }

    .prompt-line {
        font-size: 0.85rem;
        color: var(--text-dim);
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .prompt {
        color: var(--accent);
    }

    .command {
        color: var(--text-bright);
    }

    .intro {
        color: var(--text-dim);
        font-size: 0.88rem;
        margin-bottom: 2rem;
    }

    .posts {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .post {
        padding: 1.2rem 0;
        border-bottom: 1px solid var(--border);
    }

    .post-header {
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
        margin-bottom: 0.4rem;
    }

    .post-date {
        color: var(--text-dim);
        font-size: 0.8rem;
        min-width: 90px;
    }

    .post-title {
        color: var(--text-bright);
        font-size: 1rem;
    }

    .post-title:hover {
        color: var(--accent);
    }

    .post-desc {
        color: var(--text);
        font-size: 0.88rem;
        margin: 0;
        line-height: 1.6;
        padding-left: calc(90px + 1.5rem);
    }
</style>
