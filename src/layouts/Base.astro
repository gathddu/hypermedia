---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = "jess's corner of the web" } = Astro.props;
const currentPath = Astro.url.pathname;
const nav = [
  { href: '/whois', label: 'whois', icon: '₍^ >⩊< ^₎Ⳋ' },
  { href: '/code', label: 'code', icon: '</>૮・ﻌ・ა' },
  { href: '/lab', label: 'lab', icon: '⋆˚꩜｡⋆. ⌬ ˚' },
  { href: '/blog', label: 'blog', icon: '໒(⊙ᴗ⊙)७✎▤' },
];
---

<!doctype html>

<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'gathddu' ? title : `${title} :: gathddu`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body>

    <header>
      <a href="/" class="logo" aria-label="home">
        <span class="logo-bracket">[</span>
        <span class="logo-name">gathddu</span>
        <span class="logo-bracket">]</span>
      </a>
      <nav>
        {nav.map(({ href, label, icon } ) => (
          <a
            href={href}
            class:list={['nav-link', { active: currentPath.startsWith(href) }]}
          >
            <span class="nav-icon">{icon}</span>
            <span class="nav-label">{label}</span>
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <span>gathddu :: <span class="dim">made with astro + obsession</span></span>
      <span class="dim">src on <a href="https://github.com/gathddu" target="_blank" rel="noopener">github</a></span>
    </footer>

  </body>

</html>

<style>
  header {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1rem 2rem;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 100;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-bright);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .logo:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .logo-bracket {
    color: var(--accent);
  }

  .logo-name {
    color: var(--text-bright);
  }

  nav {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid transparent;
    color: var(--text-dim);
    font-size: 0.85rem;
    border-radius: 2px;
    transition: all 0.15s;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--text-bright);
    border-color: var(--border-bright);
    bakcground: var(--bg-hover);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dark);
  }

  .nav-icon {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  main {
    flex: 1;
    padding: 2.5rem 2rem;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }

  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .dim {
    color: var(--text-dim);
  }

  @media (max-width: 600px) {
    header { padding: 0.75rem 1rem; gap: 1rem; }
    main { padding: 1.5rem 1rem; }
    footer { padding: 0.75rem 1rem; flex-direction: column; gap: 0.25rem; align-items: flex-start; }
    .nav-label { display: none; }
    .nav-icon { font-size: 1rem; opacity: 1; }
  }
</style>
